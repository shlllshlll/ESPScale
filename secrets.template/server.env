# ESPScale server environment
# Copy to secrets/server.env and fill in real values.
# Load:  set -a && source secrets/server.env && set +a
# Or:    export $(grep -v '^#' secrets/server.env | xargs)

APP_API_KEY=change-me-to-a-random-32-char-string
SECRET_KEY=change-me-in-production

# Embedded MQTT (amqtt inside FastAPI process)
MQTT_ENABLED=true
MQTT_BIND=0.0.0.0
MQTT_PORT=1883
MQTT_USER=espscale
MQTT_PASS=change-me-to-a-secure-mqtt-password

# Optional
# DATABASE_URL=sqlite+aiosqlite:///espscale.db
# DATA_RETENTION_DAYS=90

# Generate keys:
#   python3 -c "import os;print(os.urandom(16).hex())"
#   python3 -c "import os;print(os.urandom(32).hex())"
